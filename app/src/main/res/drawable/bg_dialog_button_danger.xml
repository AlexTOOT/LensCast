<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_enabled="false">
        <shape android:shape="rectangle">
            <corners android:radius="14dp" />
            <solid android:color="#24C0D2D2" />
            <stroke
                android:width="1dp"
                android:color="#1FC0D2D2" />
        </shape>
    </item>
    <item android:state_pressed="true">
        <shape android:shape="rectangle">
            <corners android:radius="14dp" />
            <solid android:color="#33FF5A3D" />
            <stroke
                android:width="1dp"
                android:color="@color/ui_danger_action_pressed" />
        </shape>
    </item>
    <item>
        <shape android:shape="rectangle">
            <corners android:radius="14dp" />
            <solid android:color="@android:color/transparent" />
            <stroke
                android:width="1dp"
                android:color="@color/ui_danger_action" />
        </shape>
    </item>
</selector>
