<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_enabled="false">
        <shape android:shape="rectangle">
            <corners android:radius="7dp" />
            <solid android:color="#1730251A" />
            <stroke
                android:width="1dp"
                android:color="#246A4F34" />
        </shape>
    </item>
    <item android:state_selected="true">
        <shape android:shape="rectangle">
            <corners android:radius="7dp" />
            <gradient
                android:angle="0"
                android:endColor="@color/skin_warm_success"
                android:startColor="@color/skin_warm_accent" />
        </shape>
    </item>
    <item android:state_pressed="true">
        <shape android:shape="rectangle">
            <corners android:radius="7dp" />
            <solid android:color="#45FFCA6A" />
            <stroke
                android:width="1dp"
                android:color="@color/skin_warm_stroke_strong" />
        </shape>
    </item>
    <item>
        <shape android:shape="rectangle">
            <corners android:radius="7dp" />
            <solid android:color="#2EE7CFA9" />
            <stroke
                android:width="1dp"
                android:color="#47E7CFA9" />
        </shape>
    </item>
</selector>
