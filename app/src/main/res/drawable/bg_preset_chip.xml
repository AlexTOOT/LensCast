<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_enabled="false">
        <shape android:shape="rectangle">
            <corners android:radius="7dp" />
            <solid android:color="#1A1B2A35" />
            <stroke
                android:width="1dp"
                android:color="#263C5365" />
        </shape>
    </item>
    <item android:state_selected="true">
        <shape android:shape="rectangle">
            <corners android:radius="7dp" />
            <gradient
                android:angle="0"
                android:endColor="@color/ui_success"
                android:startColor="@color/ui_accent" />
        </shape>
    </item>
    <item android:state_pressed="true">
        <shape android:shape="rectangle">
            <corners android:radius="7dp" />
            <solid android:color="#334FE0C4" />
            <stroke
                android:width="1dp"
                android:color="@color/ui_stroke_strong" />
        </shape>
    </item>
    <item>
        <shape android:shape="rectangle">
            <corners android:radius="7dp" />
            <solid android:color="@color/ui_bg_surface_soft" />
            <stroke
                android:width="1dp"
                android:color="@color/ui_stroke" />
        </shape>
    </item>
</selector>
