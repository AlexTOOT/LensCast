<resources xmlns:tools="http://schemas.android.com/tools">
    <style name="Theme.MultiLensIpCam" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="colorPrimary">@color/ui_accent</item>
        <item name="colorPrimaryVariant">@color/ui_accent_soft</item>
        <item name="colorOnPrimary">@color/ui_bg_base</item>
        <item name="colorSecondary">@color/ui_success</item>
        <item name="colorOnSecondary">@color/ui_bg_base</item>
        <item name="colorError">@color/ui_danger</item>
        <item name="android:windowBackground">@color/ui_bg_base</item>
        <item name="android:statusBarColor" tools:targetApi="l">@android:color/transparent</item>
        <item name="android:navigationBarColor" tools:targetApi="l">@color/ui_bg_base</item>
        <item name="android:textColorPrimary">@color/ui_text_primary</item>
        <item name="android:textColorSecondary">@color/ui_text_secondary</item>
        <item name="colorControlActivated">@color/ui_success</item>
        <item name="colorControlNormal">@color/ui_stroke</item>
        <item name="android:windowLightStatusBar" tools:targetApi="m">false</item>
        <item name="android:windowLightNavigationBar" tools:targetApi="o_mr1">false</item>
    </style>

    <style name="Theme.MultiLensIpCam.Warm" parent="Theme.MultiLensIpCam">
        <item name="colorPrimary">@color/skin_warm_accent</item>
        <item name="colorPrimaryVariant">@color/skin_warm_accent_soft</item>
        <item name="colorOnPrimary">@color/skin_warm_bg_base</item>
        <item name="colorSecondary">@color/skin_warm_success</item>
        <item name="colorOnSecondary">@color/skin_warm_bg_base</item>
        <item name="colorError">@color/skin_warm_danger</item>
        <item name="android:windowBackground">@color/skin_warm_bg_base</item>
        <item name="android:navigationBarColor" tools:targetApi="l">@color/skin_warm_bg_base</item>
        <item name="android:textColorPrimary">@color/skin_warm_text_primary</item>
        <item name="android:textColorSecondary">@color/skin_warm_text_secondary</item>
        <item name="colorControlActivated">@color/skin_warm_success</item>
        <item name="colorControlNormal">@color/skin_warm_stroke</item>
    </style>

    <style name="Theme.MultiLensIpCam.Mineral" parent="Theme.MultiLensIpCam">
        <item name="colorPrimary">@color/skin_mineral_accent</item>
        <item name="colorPrimaryVariant">@color/skin_mineral_accent_soft</item>
        <item name="colorOnPrimary">@color/skin_mineral_bg_base</item>
        <item name="colorSecondary">@color/skin_mineral_success</item>
        <item name="colorOnSecondary">@color/skin_mineral_bg_base</item>
        <item name="colorError">@color/skin_mineral_danger</item>
        <item name="android:windowBackground">@color/skin_mineral_bg_base</item>
        <item name="android:navigationBarColor" tools:targetApi="l">@color/skin_mineral_bg_base</item>
        <item name="android:textColorPrimary">@color/skin_mineral_text_primary</item>
        <item name="android:textColorSecondary">@color/skin_mineral_text_secondary</item>
        <item name="colorControlActivated">@color/skin_mineral_success</item>
        <item name="colorControlNormal">@color/skin_mineral_stroke</item>
    </style>

    <style name="ThemeOverlay.MultiLensIpCam.DeleteConfirmDialog" parent="ThemeOverlay.MaterialComponents.MaterialAlertDialog">
        <item name="colorSurface">@color/ui_bg_surface</item>
        <item name="colorOnSurface">@color/ui_text_primary</item>
        <item name="colorPrimary">@color/ui_danger_action</item>
        <item name="colorOnPrimary">@color/ui_bg_base</item>
        <item name="colorError">@color/ui_danger_action</item>
        <item name="android:windowBackground">@drawable/bg_dialog_surface</item>
        <item name="android:backgroundDimAmount">0.72</item>
        <item name="buttonBarPositiveButtonStyle">@style/Widget.MultiLensIpCam.DialogButton.Danger</item>
        <item name="buttonBarNegativeButtonStyle">@style/Widget.MultiLensIpCam.DialogButton.Secondary</item>
    </style>

    <style name="Widget.MultiLensIpCam.DialogButton.Danger" parent="Widget.MaterialComponents.Button.TextButton.Dialog">
        <item name="android:textColor">@color/ui_text_primary</item>
        <item name="iconTint">@color/ui_text_primary</item>
        <item name="rippleColor">#33FFFFF0</item>
    </style>

    <style name="Widget.MultiLensIpCam.DialogButton.Secondary" parent="Widget.MaterialComponents.Button.TextButton.Dialog">
        <item name="android:textColor">@color/ui_text_secondary</item>
        <item name="iconTint">@color/ui_text_secondary</item>
        <item name="rippleColor">#1FC0D2D2</item>
    </style>
</resources>
